# Strapi Configuration
# URL base del backend Strapi (desarrollo o producción)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# API Token de Strapi (Recomendado para lectura pública)
# Para obtener un token: Strapi Admin → Settings → Global settings → API Tokens → Create new API Token
# Token type: Read-only (para solo lectura) o Full access (para leer/escribir)
# Este token se usa para operaciones públicas de lectura (domos, temporadas, páginas, testimonios)
# STRAPI_API_TOKEN=your_api_token_here

# Alternativa: Token accesible desde el cliente (menos seguro, pero necesario para Client Components)
# Se usa cuando las páginas son "use client" y necesitan acceso al token
# NEXT_PUBLIC_STRAPI_API_TOKEN=your_token_here

# NOTA: Para operaciones autenticadas (como crear reservas), el código usa JWT tokens
# Los JWT se obtienen mediante login (ver lib/auth.ts) y se almacenan en localStorage

# Next.js Configuration
# URL base del sitio frontend (usado para generar URLs absolutas)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp
# Número de WhatsApp para el modal de consulta (sin + ni espacios, con código de país)
NEXT_PUBLIC_WHATSAPP_NUMBER=5491100000000

# Notas:
# - NEXT_PUBLIC_STRAPI_URL: Debe coincidir con la URL donde corre tu backend Strapi
#   Para producción, cambia a: https://tu-backend-strapi.com
# - Las variables que empiezan con NEXT_PUBLIC_ son accesibles en el cliente (browser)
# - STRAPI_API_TOKEN solo es necesario si necesitas crear/editar contenido desde el frontend
#   con permisos autenticados 