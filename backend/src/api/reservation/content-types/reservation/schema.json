{
  "kind": "collectionType",
  "collectionName": "reservations",
  "info": {
    "singularName": "reservation",
    "pluralName": "reservations",
    "displayName": "Reservation"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "domo": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::domo.domo",
      "inversedBy": "reservations"
    },
    "guestName": {
      "type": "string",
      "required": true
    },
    "guestEmail": {
      "type": "email",
      "required": true
    },
    "guestPhone": {
      "type": "string"
    },
    "checkIn": {
      "type": "date",
      "required": true
    },
    "checkOut": {
      "type": "date",
      "required": true
    },
    "totalPrice": {
      "type": "decimal",
      "required": true
    },
    "reservationStatus": {
      "type": "enumeration",
      "default": "draft",
      "enum": [
        "draft",
        "confirmed",
        "cancelled",
        "completed"
      ]
    },
    "paymentStatus": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "paid",
        "failed",
        "refunded"
      ]
    },
    "specialRequests": {
      "type": "text"
    },
    "numberOfGuests": {
      "type": "integer",
      "required": true,
      "min": 1
    }
  }
}
