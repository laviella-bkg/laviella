{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "guestName": {
      "type": "string",
      "required": true
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5
    },
    "comment": {
      "type": "text",
      "required": true
    },
    "isApproved": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "guestImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "domo": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::domo.domo",
      "inversedBy": "testimonials"
    }
  }
}
